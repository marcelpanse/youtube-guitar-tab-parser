{
  "name": "tab-parser",
  "version": "0.1.0",
  "description": "CLI that turns a YouTube guitar-lesson video into a PDF of the guitar tab",
  "type": "module",
  "bin": {
    "tab-parser": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "commander": "^15.0.0",
    "execa": "^9.6.1",
    "pdf-lib": "^1.17.1",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
